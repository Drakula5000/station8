# Required
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Access passwords (if unset, the app prompts you to create them in the browser)
OWNER_PASSWORD=
VISITOR_PASSWORD=

# Supabase (required for persistent storage; without these, data is local-only)
SUPABASE_URL=
SUPABASE_KEY=

# Google OAuth (optional — enables Google Docs/Sheets integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5001/api/google/callback
